{
  "extends": [
    "development"
  ],
  "hints": {
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "backdrop-filter",
          "min-height: auto",
          "border-color: color-mix(in srgb, var(--accent) 76%, #000)",
          "border: 1px solid color-mix(in srgb, var(--success) 36%, transparent)"
        ]
      }
    ],
    "no-inline-styles": "off"
  }
}